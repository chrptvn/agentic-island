{
  "tileSize": 64,
  "spriteDir": "LPC Characters",
  "animations": {
    "idle":   { "frames": 2, "fps": 4 },
    "walk":   { "frames": 9, "fps": 12 },
    "slash":  { "frames": 6, "fps": 12 },
    "thrust": { "frames": 8, "fps": 12 }
  },
  "directionOrder": ["n", "w", "s", "e"],
  "compositeLayout": {
    "idle":   { "startRow": 0 },
    "walk":   { "startRow": 4 },
    "slash":  { "startRow": 8 },
    "thrust": { "startRow": 12 }
  },
  "genders": ["male", "female"],
  "skinColors": ["amber", "black", "bronze", "brown", "light", "olive"],
  "layers": {
    "body": {
      "order": 0,
      "required": true,
      "pathTemplate": "bodies/{item}/{gender}/{anim}.png"
    },
    "feet": {
      "order": 1,
      "required": false,
      "items": ["boots", "shoes", "slippers"],
      "pathTemplate": "clothing/feet/{item}/{gender}/{color}/{anim}.png",
      "colors": ["brown", "black", "blue", "forest", "gray", "navy", "red", "tan"],
      "colorKey": "feet_color"
    },
    "legs": {
      "order": 2,
      "required": false,
      "items": ["pants", "shorts", "skirt"],
      "pathTemplate": "clothing/legs/{item}/{gender}/{color}/{anim}.png",
      "colors": ["brown", "black", "blue", "forest", "gray", "navy", "red", "tan"],
      "colorKey": "legs_color",
      "itemGenders": { "shorts": ["male"] }
    },
    "torso": {
      "order": 3,
      "required": false,
      "items": ["sleeveless", "laced", "blouse_longsleeve"],
      "pathTemplate": "clothing/torso/{item}/{gender}/{color}/{anim}.png",
      "colors": ["brown", "black", "blue", "forest", "gray", "navy", "red", "tan"],
      "colorKey": "torso_color",
      "itemGenders": { "laced": ["male"], "blouse_longsleeve": ["female"] }
    },
    "outerwear": {
      "order": 4,
      "required": false,
      "items": ["vest", "apron", "jacket", "corset", "tabard"],
      "pathTemplate": "clothing/torso/{item}/{gender}/{color}/{anim}.png",
      "colors": ["brown", "black", "blue", "forest", "gray", "navy", "red", "tan"],
      "colorKey": "outerwear_color",
      "itemGenders": { "vest": ["male"], "jacket": ["male"], "corset": ["female"] }
    },
    "headwear": {
      "order": 6,
      "required": false,
      "items": ["headband", "tophat", "leather_cap"],
      "pathTemplate": "clothing/headwear/{item}/{anim}.png",
      "colorableItems": ["headband", "tophat"],
      "colorPathTemplate": "clothing/headwear/{item}/{color}/{anim}.png",
      "colors": ["brown", "black", "blue", "forest", "gray", "navy", "red", "tan"],
      "colorKey": "headwear_color"
    },
    "hair": {
      "order": 5,
      "required": true,
      "items": ["afro", "bangs", "bangsshort", "bob", "buzzcut", "cornrows", "curly_short", "dreadlocks_short", "half_up", "long", "long_straight", "loose", "parted", "pixie", "shorthawk", "spiked"],
      "pathTemplate": "hair/{item}/{color}/{anim}.png",
      "colors": ["ash", "black", "blonde", "blue", "carrot", "chestnut", "dark_brown", "dark_gray", "ginger", "gold", "gray", "green", "light_brown", "navy", "orange", "pink", "platinum", "purple", "raven", "red", "redhead", "rose", "sandy", "strawberry", "violet", "white"],
      "colorKey": "hair_color"
    }
  },
  "tools": {
    "axe":      { "action": "slash",  "pathPrefix": "tools/axe",       "overlaySize": 128 },
    "hammer":   { "action": "slash",  "pathPrefix": "tools/hammer",    "overlaySize": 128 },
    "pickaxe":  { "action": "slash",  "pathPrefix": "tools/pickaxe",   "overlaySize": 128 },
    "hoe":      { "action": "thrust", "pathPrefix": "tools/hoe",       "overlaySize": 64 },
    "shovel":   { "action": "thrust", "pathPrefix": "tools/shovel",    "overlaySize": 64 },
    "watering": { "action": "thrust", "pathPrefix": "tools/watering",  "overlaySize": 64 },
    "dagger":   { "action": "slash",  "pathPrefix": "weapons/dagger",  "overlaySize": 64 },
    "spear":    { "action": "thrust", "pathPrefix": "weapons/spear",   "overlaySize": 64 },
    "sword":    { "action": "slash",  "pathPrefix": "weapons/sword",   "overlaySize": 64 }
  },
  "toolItemMapping": {
    "stone_axe":     "axe",
    "stone_pickaxe": "pickaxe",
    "stone_knife":   "dagger",
    "plow":          "hoe",
    "hammer":        "hammer",
    "shovel":        "shovel",
    "watering_can":  "watering",
    "spear":         "spear",
    "sword":         "sword"
  }
}
