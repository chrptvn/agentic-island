    "nodemailer": "^8.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
