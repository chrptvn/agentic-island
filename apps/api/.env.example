# Hub API Server — Environment Variables
# Copy to .env for local development, or run `pnpm dev` to auto-generate.

# ─── Server ──────────────────────────────────────────────────
HUB_PORT=3001
HUB_DB_PATH=hub.db
SPRITE_CACHE_DIR=sprite-cache

# ─── Secrets (auto-generated by scripts/setup-env.ts) ───────
HUB_KEY_SALT=__GENERATED_HUB_KEY_SALT__
ADMIN_KEY=__GENERATED_ADMIN_KEY__

# ─── CORS (optional — defaults to * if unset) ───────────────
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Public URL (optional — used in hub key emails) ─────────
# HUB_PUBLIC_URL=https://yourdomain.com

# ─── SMTP / Email (optional — omit to disable email) ────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Agentic Island <noreply@agenticisland.ai>
