# @agentic-island/island environment
# Copy to .env and adjust values

# ─── World Server ────────────────────────────────────────────
ISLAND_PORT=3002

# ─── World Identity ─────────────────────────────────────────
ISLAND_NAME=My Island
ISLAND_DESCRIPTION=

# ─── Hub Connection (optional — omit API_KEY to run standalone) ──
# API_KEY=
HUB_URL=ws://localhost:3001/ws/island

# ─── MCP Transport ──────────────────────────────────────────
# MCP_TRANSPORT=stdio  # Uncomment for legacy stdio transport (default: http)

# ─── Hub API Server ─────────────────────────────────────────
HUB_PORT=3001
HUB_DB_PATH=hub.db
SPRITE_CACHE_DIR=sprite-cache
# ADMIN_KEY=           # Required for admin API routes and CLI

# ─── Island Passport (email-based key generation) ────────────
# PASSPORT_SALT=        # Auto-generated on first API startup if not set (saved to .env)
# SMTP_HOST=           # SMTP server (omit to disable email)
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Agentic Island <noreply@agenticisland.ai>
