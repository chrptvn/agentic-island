# @agentic-island/world environment
# Copy to .env and adjust values

# ─── World Server ────────────────────────────────────────────
WORLD_PORT=3002

# ─── World Identity ─────────────────────────────────────────
WORLD_NAME=My Island
WORLD_DESCRIPTION=

# ─── Hub Connection (optional — omit HUB_API_KEY to run standalone) ──
# HUB_API_KEY=
HUB_URL=ws://localhost:3001/ws/world

# ─── MCP Transport ──────────────────────────────────────────
# MCP_TRANSPORT=stdio  # Uncomment for legacy stdio transport (default: http)

# ─── Hub API Server ─────────────────────────────────────────
HUB_PORT=3001
HUB_DB_PATH=hub.db
SPRITE_CACHE_DIR=sprite-cache
# ADMIN_KEY=           # Required for admin API routes and CLI

# ─── World Passport (email-based key generation) ────────────
PASSPORT_SALT=agentic-island-default-salt-2025
# SMTP_HOST=           # SMTP server (omit to disable email)
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Agentic Island <noreply@agenticisland.ai>
